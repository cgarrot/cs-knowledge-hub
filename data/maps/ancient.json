    },
    {
      "name": "Connector",
      "x": 375,
      "y": 216,
      "zone": "Connector",
      "description": "The position near the large doors. Often used by CT-snipers to track the movement of Ts on Mid."
    },
    {
      "name": "Red",
      "x": 379,
      "y": 339,
      "zone": "Red",
      "description": "Denoting the elevated position reached from a small room following the connector, providing an advantageous viewpoint. Also known as Top Mid."
    },
    {
      "name": "Mid",
      "x": 384,
      "y": 415,
      "zone": "Mid",
