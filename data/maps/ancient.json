      "y": 562,
      "zone": "Ruins",
      "description": "The enclosed area near Doors where Ts can wait for aggressive pushes or throw smokes on the B Site."
    },
    {
      "name": "Elbow",
      "x": 300,
      "y": 458,
      "zone": "Elbow",
      "description": "The compact zone nestled around the corner, serving as a link between the middle of the map and the Split area. Also known as Lower Mid."
    },
    {
      "name": "Short",
      "x": 246,
      "y": 302,
      "zone": "Short",
      "description": "The passage from Donut to A Site. Hard to push as it can be controlled from many spots."
    },
    {
      "name": "Donut",
      "x": 250,
      "y": 371,
      "zone": "Donut",
