    },
    {
      "name": "A Main",
      "x": 149,
      "y": 326,
      "zone": "A Main",
      "description": "The area of the map between Long and A Halls. This is where Ts can most often hide when they are about to enter the A Site."
    },
    {
      "name": "A Boost",
      "x": 191,
      "y": 274,
      "zone": "A Boost",
      "description": "The high rise where one player can boost the other to provide closed control of the Long area."
    },
    {
      "name": "A Halls",
      "x": 155,
      "y": 397,
      "zone": "A Halls",
      "description": "The narrow corridor between Stairs and A Main."
    },
    {
      "name": "Stairs",
      "x": 182,
      "y": 451,
      "zone": "Stairs",
      "description": "The staircase leading to the A Site from the T Spawn. Pressing Shift here will help you to ensure the CTs on A Site won't hear you, when you play for Ts."
    },
    {
      "name": "Split",
