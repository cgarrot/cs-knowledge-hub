# Environment variables
# Copy to .env.local and fill in values

# SQLite database path (default: /data/cs-knowledge.db for production)
DB_PATH=/data/cs-knowledge.db

# Ollama Cloud LLM configuration
OLLAMA_BASE_URL=https://api.ollama.cloud
OLLAMA_API_KEY=your-api-key-here
OLLAMA_MODEL=llama3

# Embedding API (can be same as Ollama)
EMBEDDING_API_URL=
EMBEDDING_MODEL=nomic-embed-text

# Category index path
CATEGORY_INDEX_PATH=/home/ubuntu/cs-knowledge/categories/full-index.json

# Data directory for Docker volume
DATA_DIR=/data
