  "callouts": [
    {
      "name": "T Spawn",
      "x": 525,
      "y": 743,
      "zone": "T Spawn",
      "description": "The Terrorist starting area. Most T-side routes begin from here."
    },
    {
      "name": "Playground",
      "x": 330,
      "y": 654,
      "zone": "Playground",
      "description": "The playground section near Fountain. It is an easy landmark and a common early-round staging area."
    },
    {
      "name": "Fountain",
      "x": 353,
      "y": 580,
      "zone": "Fountain",
      "description": "The fountain area near Mid on the A side. Teams often start here before deciding how to take map control."
    },
    {
      "name": "Party",
      "x": 263,
      "y": 480,
      "zone": "Party",
      "description": "The picnic area next to Mid marked by balloons. Also known as Balloons. Both names usually refer to the same section."
    },
    {
      "name": "Upper Tunnels",
      "x": 539,
      "y": 598,
      "zone": "Upper Tunnels",
      "description": "The upper tunnel leading away from spawn. It connects into the lower tunnel system."
    },
    {
      "name": "Ladder",
      "x": 480,
      "y": 573,
      "zone": "Ladder",
      "description": "The ladder between Upper and Lower Tunnels. It is a simple callout, but useful for tracking movement and timing."
    },
    {
      "name": "Lower Tunnels",
      "x": 447,
      "y": 509,
      "zone": "Lower Tunnels",
      "description": "The lower tunnel area after the ladder. It leads toward Connector and the lower B-side routes."
    },
    {
      "name": "Squeaky",
      "x": 460,
      "y": 403,
      "zone": "Squeaky",
      "description": "The door leading from Connector or Lower Tunnel into Water. It is a narrow choke point and often called during utility usage or quick pushes."
    },
    {
      "name": "Water",
      "x": 501,
      "y": 372,
      "zone": "Water",
      "description": "The low area between Connector, Short Tunnel, and B Short. It is one of the most important lower-map callouts on Overpass."
    },
    {
      "name": "A Long",
      "x": 146,
      "y": 424,
      "zone": "A Long",
      "description": "The wide outside approach into A from the park side. Teams often use it for slower control or split hits."
    },
    {
      "name": "Hitmarker",
      "x": 187,
      "y": 611,
      "zone": "Hitmarker",
      "description": "Hitmarker refers to the spot right at the start of A Long, where Terrorists first show themselves. The callout comes from frequent AWP wallbangs that land through the wall and leave enemies badly hurt but alive."
    },
    {
      "name": "Rock",
      "x": 195,
      "y": 541,
      "zone": "Rock",
      "description": "The rock on the T side of A Long. It is one of the first common cover spots when taking Long control."
    },
    {
      "name": "Tree",
      "x": 144,
      "y": 475,
      "zone": "Tree",
      "description": "The tree on A Long. It is a simple landmark that players use constantly in Long fights."
    },
    {
      "name": "Long Boost",
      "x": 183,
      "y": 335,
      "zone": "Long Boost",
      "description": "The raised spot near Long where players can boost or hold elevated angles. It is mainly used for surprise positioning."
    },
    {
      "name": "Cafe",
      "x": 222,
      "y": 319,
      "zone": "Cafe",
      "description": "Located opposite the bench, this callout refers to the cafe sign on the other side of the Long Toilets wall."
    },
    {
      "name": "Bench",
      "x": 179,
      "y": 293,
      "zone": "Bench",
      "description": "This bench is located directly opposite Cafe."
    },
    {
      "name": "Long Toilets",
      "x": 236,
      "y": 386,
      "zone": "Long Toilets",
      "description": "The farther section of Toilets leading toward A Long. Fights here often decide who gains access to A."
    },
    {
      "name": "Toilets",
      "x": 333,
      "y": 345,
      "zone": "Toilets",
      "description": "The indoor path from Mid toward A. It is one of the most important control areas on the map."
    },
    {
      "name": "Mid",
      "x": 334,
      "y": 462,
      "zone": "Mid",
      "description": "The central area of the map between Fountain, Party, Toilets, and Connector. It is the main zone that links the upper and lower parts of Overpass."
    },
    {
      "name": "Connector",
      "x": 415,
      "y": 464,
      "zone": "Connector",
      "description": "The stair and tunnel route linking Mid to the lower part of the map. It is very important for rotations and split pressure."
    },
    {
      "name": "A Short",
      "x": 339,
      "y": 263,
      "zone": "A Short",
      "description": "The shorter route from Mid and Toilets into A. It is the quicker entry path compared to Long."
    },
    {
      "name": "Flowers",
      "x": 334,
      "y": 222,
      "zone": "Flowers",
      "description": "The flowerbed near the A entrance. Players sometimes hide or crouch around it, so it can matter in close fights."
    },
    {
      "name": "Alley",
      "x": 606,
      "y": 521,
      "zone": "Alley",
      "description": "Located in front of T Spawn, this is the first spot on the path furthest to the right."
    },
    {
      "name": "Tracks",
      "x": 672,
      "y": 451,
      "zone": "Tracks",
      "description": "The area under the train tracks on the B side. It connects toward Monster and Short Tunnel."
    },
    {
      "name": "Monster",
      "x": 651,
      "y": 346,
      "zone": "Monster",
      "description": "The large tunnel leading from T side into B. It is the main entrance for many B hits."
    },
    {
      "name": "Sewers",
      "x": 658,
      "y": 257,
      "zone": "Sewers",
      "description": "The watery area just outside Monster before entering B. Teams often group there before pushing onto the site."
    },
    {
      "name": "Barrels",
      "x": 609,
      "y": 209,
      "zone": "Barrels",
      "description": "The barrel stack on or near B Site. It gives cover and is often used by defenders holding the main entrance."
    },
    {
      "name": "B Site",
      "x": 555,
      "y": 244,
      "zone": "B Site",
      "description": "The main bomb plant area on B. This callout usually means the wooden site platform and nearby fighting space."
    },
    {
      "name": "Pillar",
      "x": 585,
      "y": 262,
      "zone": "Pillar",
      "description": "The large pillar in the middle of B Site. It is one of the key cover spots on the site and gets called constantly."
    },
    {
      "name": "Pit",
      "x": 495,
      "y": 229,
      "zone": "Pit",
      "description": "The low water area behind B under Heaven. It is commonly used during retakes and for players dropping down from above."
    },
    {
      "name": "Bridge",
      "x": 548,
      "y": 308,
      "zone": "Bridge",
      "description": "The path at the back of B connecting the site toward Graffiti and the CT side. It is usually called when someone is crossing that lane."
    },
    {
      "name": "Heaven",
      "x": 468,
      "y": 191,
      "zone": "Heaven",
      "description": "The raised platform overlooking B from the CT side. It is one of the strongest defending and retake positions on the site."
    },
    {
      "name": "B Short",
      "x": 576,
      "y": 366,
      "zone": "B Short",
      "description": "The route from Water into B Site. Some players also call it Construction, and it is one of the main split paths into the bombsite."
    },
    {
      "name": "Sandbags",
      "x": 574,
      "y": 338,
      "zone": "Sandbags",
      "description": "The sandbags on B Short near the site entrance. It is one of the most common close positions on B."
    },
    {
      "name": "Short Tunnel",
      "x": 586,
      "y": 409,
      "zone": "Short Tunnel",
      "description": "The tunnel leading from Tracks toward Water. It is part of the route used to pressure B Short."
    },
    {
      "name": "Graffiti",
      "x": 442,
      "y": 345,
      "zone": "Graffiti",
      "description": "The back-site corner with graffiti on the wall. It is a classic B anchor spot and an important point of reference."
    },
    {
      "name": "Storage",
      "x": 349,
      "y": 34,
      "zone": "Storage",
      "description": "The room between Bank and the nearby stairs on the A side. It is a more niche callout, but still useful for tracking rotations."
    },
    {
      "name": "Bank",
      "x": 345,
      "y": 92,
      "zone": "Bank",
      "description": "The building behind A Site on the CT side. It overlooks the site and is a very common defensive position."
    },
    {
      "name": "Signpost",
      "x": 317,
      "y": 190,
      "zone": "Signpost",
      "description": "The sign near the A entrances from Long and Short. It is a smaller detail callout, but useful for very specific positioning."
    },
    {
      "name": "Van",
      "x": 313,
      "y": 118,
      "zone": "Van",
      "description": "The van next to Bank at the back of A. It is usually called when someone is hiding or fighting around that cover."
    },
    {
      "name": "Dumpster",
      "x": 412,
      "y": 113,
      "zone": "Dumpster",
      "description": "The back-A area near the CT side behind the site. Different players may use slightly different names for this spot, but both usually refer to that same section."
    },
    {
      "name": "CT",
      "x": 450,
      "y": 94,
      "zone": "CT",
      "description": "The Counter-Terrorist rotation route on the B side. Depending on context, it may mean the stairs or the general CT-side path. Also known as CT Stairs."
    },
    {
      "name": "A Site",
      "x": 357,
      "y": 147,
      "zone": "A Site",
      "description": "The main bomb plant area on A. When players call “site,” they usually mean the open default fighting space itself."
    },
    {
      "name": "Optimus",
      "x": 413,
      "y": 184,
      "zone": "Optimus",
      "description": "The large truck on A Site. It gives strong cover and is often used as a landmark during fights."
    },
    {
      "name": "CT Spawn",
      "x": 385,
      "y": 125,
      "zone": "CT Spawn",
      "description": "The area where Counter-Terrorists spawn and rotate to A or B Sites."
    },
    {
      "name": "Default",
      "x": 202,
      "y": 107,
      "zone": "Default",
      "description": "The most common plant spot on A, located near the green boxes. It is one of the standard references in post-plant and retake situations."
    },
    {
      "name": "Close Left",
      "x": 259,
      "y": 155,
      "zone": "Close Left",
      "description": "The close corner on the left side when exiting Long onto A. It is a dangerous angle that attackers usually need to clear carefully."
    },
    {
      "name": "Walkway",
      "x": 457,
      "y": 285,
      "zone": "Walkway",
      "description": "The path under Heaven on the CT side of B. It links the back-site area with the rotation route and is important in retakes."
    }
