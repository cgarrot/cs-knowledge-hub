# Environment variables
# Copy to .env.local and fill in values

# SQLite database path (default: /data/cs-knowledge.db for production)
DB_PATH=/data/cs-knowledge.db

# OpenAI-compatible LLM configuration
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat

# Optional Ollama-compatible fallback key used by lib/llm.ts
OLLAMA_API_KEY=

# CS2 base SVG radar maps used by tactical map rendering
CS_MAP_SVG_DIR=/home/ubuntu/zob/cs-zob-v1/map

# Embedding API (can be same as Ollama)
EMBEDDING_API_URL=
EMBEDDING_MODEL=nomic-embed-text

# Category index path
CATEGORY_INDEX_PATH=/home/ubuntu/cs-knowledge/categories/full-index.json

# Data directory for Docker volume
DATA_DIR=/data
